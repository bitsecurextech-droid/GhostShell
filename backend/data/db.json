// ... your imports

const adapter = new JSONFile('data/db.json');
const db = new Low(adapter);

async function initializeDatabase() {
    await db.read();
    
    // This is the key fix: ensure db.data is an object before setting defaults
    db.data ||= {};
    
    // Now safely initialize each of your required arrays
    db.data.users ||= [];
    db.data.accessCodes ||= [];
    db.data.tools ||= [];
    db.data.payments ||= [];
    db.data.visitors ||= [];
    db.data.websites ||= [];
    db.data.esim ||= [];
    db.data.logistics ||= [];
    db.data.virtualnums ||= [];
    db.data.webrequests ||= [];
    db.data.credforms ||= [];
    db.data.cloudreqs ||= [];
    db.data.blog ||= [];
    
    await db.write();
}

// Call this function before starting your server
initializeDatabase().then(() => {
    // ... rest of your app.listen code
});
